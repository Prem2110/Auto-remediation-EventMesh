# ============================================================
# SAP CPI Self-Healing Agent — Client Configuration Template
# Copy to .env and fill in every value before deploying.
# On SAP BTP Cloud Foundry, set these as CF environment variables
# (cf set-env <app> KEY VALUE) or in manifest.yml env: block.
# ============================================================


# ============================================================
# MCP SERVERS  (client-specific CF-deployed MCP apps)
# Each client deploys these three MCP servers and provides the URLs.
# ============================================================
MCP_INTEGRATION_SUITE_URL=https://<integration-suite-mcp>.<region>.hana.ondemand.com/mcp
MCP_TESTING_URL=https://<testing-mcp>.<region>.hana.ondemand.com/mcp
MCP_DOCUMENTATION_URL=https://<documentation-mcp>.<region>.hana.ondemand.com/mcp


# ============================================================
# SAP AI Core  (LLM backbone)
# ============================================================
AICORE_CLIENT_ID=<your-aicore-client-id>
AICORE_CLIENT_SECRET=<your-aicore-client-secret>
AICORE_AUTH_URL=https://<subdomain>.authentication.<region>.hana.ondemand.com
AICORE_BASE_URL=https://api.ai.prod.<region>.aws.ml.hana.ondemand.com/v2
AICORE_RESOURCE_GROUP=default
LLM_DEPLOYMENT_ID=<your-deployment-id>
# Optional LLM resilience tunings (falls back to 5 retries, 60s timeout if omitted)
# LLM_MAX_RETRIES=5
# LLM_REQUEST_TIMEOUT=60.0


# ============================================================
# SAP Integration Suite — Design-Time API  (iFlow get/update/deploy)
# ============================================================
API_BASE_URL=https://<tenant>.it-cpi<num>.cfapps.<region>.hana.ondemand.com/api/v1
API_OAUTH_CLIENT_ID=<your-client-id>
API_OAUTH_CLIENT_SECRET=<your-client-secret>
API_OAUTH_TOKEN_URL=https://<tenant>.authentication.<region>.hana.ondemand.com/oauth/token


# ============================================================
# SAP Integration Suite — Runtime / Monitoring API  (message logs, error details)
# ============================================================
CPI_BASE_URL=https://<tenant>.it-cpi<num>-rt.cfapps.<region>.hana.ondemand.com
CPI_OAUTH_CLIENT_ID=<your-client-id>
CPI_OAUTH_CLIENT_SECRET=<your-client-secret>
CPI_OAUTH_TOKEN_URL=https://<tenant>.authentication.<region>.hana.ondemand.com/oauth/token


# ============================================================
# SAP Integration Suite — Autonomous Error Polling
# Used by the CPI Monitor to fetch failed messages on a schedule.
# ============================================================
SAP_HUB_TENANT_URL=https://<tenant>.it-cpi<num>.cfapps.<region>.hana.ondemand.com
SAP_HUB_TOKEN_URL=https://<tenant>.authentication.<region>.hana.ondemand.com/oauth/token
SAP_HUB_CLIENT_ID=<your-client-id>
SAP_HUB_CLIENT_SECRET=<your-client-secret>


# ============================================================
# SAP HANA Cloud  (incident store, fix patterns, history)
# ============================================================
HANA_HOST=<uuid>.hna0.prod-<region>.hanacloud.ondemand.com
HANA_PORT=443
HANA_USER=<your-hana-user>
HANA_PASSWORD=<your-hana-password>
HANA_SCHEMA=<your-schema>


# ============================================================
# AWS S3 Object Store  (XSD/document uploads)
# ============================================================
BUCKET_NAME=<your-bucket-name>
REGION=us-east-1
ENDPOINT_URL=https://s3.amazonaws.com
OBJECT_STORE_ACCESS_KEY=<your-access-key>
OBJECT_STORE_SECRET_KEY=<your-secret-key>


# ============================================================
# SAP Event Mesh — Pipeline messaging
#
# Topic layout (all derived from EM_QUEUE_PREFIX):
#   {EM_QUEUE_PREFIX}/orchestrator  — raw CPI error ingress
#   {EM_QUEUE_PREFIX}/observer      — OData enrichment
#   {EM_QUEUE_PREFIX}/rca           — root cause analysis
#   {EM_QUEUE_PREFIX}/fixer         — fix + deploy
#   {EM_QUEUE_PREFIX}/verifier      — post-fix verification
#
# Webhook endpoints (configure in SAP Event Mesh admin UI):
#   POST <app-url>/agents/orchestrator
#   POST <app-url>/agents/observer
#   POST <app-url>/agents/rca
#   POST <app-url>/agents/fixer
#   POST <app-url>/agents/verifier
# ============================================================

# Master switch — false = in-process only (local dev), true = real SAP Event Mesh
EM_ENABLED=true

# SAP Event Mesh REST endpoint base URL (from service key, "httprest" protocol URL)
EM_REST_URL=https://<em-service-host>.enterprise-messaging.cfapps.<region>.hana.ondemand.com

# Topic prefix — must match the namespace configured in your SAP Event Mesh service
# Example: default/acme.corp/1/autofix/orbit
EM_QUEUE_PREFIX=default/<namespace>/1/autofix/orbit

# Ingest topic — the topic CPI Monitor publishes to (orchestrator queue subscribes here)
# Example: default/acme.corp/1/autofix/in
EM_INGEST_TOPIC=default/<namespace>/1/autofix/in

# BTP Destination name that holds the Event Mesh OAuth token (default: EventMesh)
EVENT_MESH_DESTINATION_NAME=EventMesh

# OAuth2 credentials for Event Mesh (from service key, "uaa" section)
EVENT_MESH_TOKEN_URL=https://<subdomain>.authentication.<region>.hana.ondemand.com/oauth/token
EVENT_MESH_CLIENT_ID=<your-event-mesh-client-id>
EVENT_MESH_CLIENT_SECRET=<your-event-mesh-client-secret>


# ============================================================
# Autonomous Operations — Pipeline behaviour
# ============================================================

# Enable the background CPI polling loop
AUTONOMOUS_ENABLED=false

# Seconds between CPI message log polls
CPI_POLL_INTERVAL_SECONDS=600

# Confidence threshold for fully automatic fix (no human approval)
AUTO_FIX_CONFIDENCE=0.90

# Confidence threshold for suggesting a fix (below → create ticket)
SUGGEST_FIX_CONFIDENCE=0.70

# true  → auto-fix every fixable error type regardless of policy
# false → respect per-error-type policy (AUTO_FIX / APPROVAL / RETRY / TICKET)
AUTO_FIX_ALL_CPI_ERRORS=false

# true → automatically deploy the iFlow after a successful fix update
AUTO_DEPLOY_AFTER_FIX=true

# How many consecutive failures for the same iFlow before auto-escalating to a ticket
MAX_CONSECUTIVE_FAILURES=5

# Hours an incident can stay AWAITING_APPROVAL before auto-escalating
PENDING_APPROVAL_TIMEOUT_HRS=24

# Seconds within which repeat errors for the same iFlow are absorbed (burst dedup)
BURST_DEDUP_WINDOW_SECONDS=60

# Max failed messages fetched per polling cycle
FAILED_MESSAGE_FETCH_LIMIT=100

# Default assignee email/ID stamped on auto-created escalation tickets (leave blank for unassigned)
TICKET_DEFAULT_ASSIGNEE=


# ============================================================
# ITSM Integration  (via SAP BTP Destination "ITSM-Sierra")
# The destination base URL and bearer token are injected at runtime
# via VCAP_SERVICES — do NOT hardcode them here.
# ============================================================

# SAP user UUID used as requester_ID on all auto-created tickets
ITSM_REQUESTER_ID=<your-sap-user-uuid>

# Environment tag stamped on every ticket (e.g. production, staging, dev)
CPI_ENVIRONMENT=production

# Seconds between closed-ticket status polls
ITSM_POLL_INTERVAL=300


# ============================================================
# Server & Logging
# ============================================================
API_HOST=0.0.0.0
# PORT is auto-set by Cloud Foundry — only needed for local dev
API_PORT=8080
LOG_LEVEL=INFO
ENABLE_CONSOLE_LOGS=true
